{
    "engine": "neuPrint-neo4j",
    "engine-config": {
	    "server": "<NEO4-SERVER>:7474",
	    "user": "neo4j",
	    "password": "<PASSWORD>"
    },
    "mainstore-alternatives": [
      {
        "engine": "neuPrint-neo4j",
        "engine-config": {
          "server": "<NEO4-SERVER>:7474",
          "user": "neo4j",
          "password": "<PASSWORD>"
        }
      }
    ],
    "datatypes": {
      "skeletons" : [
        {
          "instance": "<UNIQUE NAME>",
          "engine": "dvidkv",
          "engine-config": {
            "dataset": "hemibrain",
            "server": "http://<DVIDADDR>",
            "branch": "<UUID>",
            "instance": "segmentation_skeletons"
          }
        },
        {
          "instance": "<UNIQUE NAME>",
          "engine": "badger",
          "engine-config": {
            "dataset": "hemibrain",
            "location": "<DIRECTORY LOCATION>"
          }
        }
      ]
    },
    "roimeshes": [
      {
        "instance": "<name>_roimesh",
        "engine": "dvidkv",
        "engine-config": {
          "dataset": "<dataset_name>",
          "server": "https://<DVIDADDR>",
          "branch": "<UUID>",
          "instance": "roisSmoothedDecimated",
          "token": "<JWT access token if needed>"
        }
      }
    ],
    "arrow-flight-port": 11001,
    "disable-auth": false,
    "dsg-url": "<DATASETGATEWAY BASE URL, e.g. https://dsg.janelia.org>",
    "dsg-cache-ttl": 300,
    "dsg-service-name": "neuprint",
    "dataset-map": {
      "vnc": "VNC",
      "manc": "MANC"
    },
    "hostname": "<HOSTNAME FOR THIS SERVER>",
    "log-file": "log.json",
    "ng-dir": "<PATH TO NEUROGLANCER LAYERS DIRECTORY>",
    "swagger-docs": "<NEUPRINT_HTTP_LOCATION>/swaggerdocs",
    "ssl-cert": "<PATH TO SSL CERTIFICATE FILE>",
    "ssl-key": "<PATH TO SSL KEY FILE>",
    "static-dir": "<PATH TO STATIC FILES, I.E. REACT BUILD>",
    "vimo-server": "<VIMO CLOUD FUNC URL>"
}
